# Copy this to .env.staging for local live-like testing.
# Use a separate Supabase project/database from production.
# Quote values that contain special shell characters.

SUPABASE_URL="https://staging-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="replace-with-staging-publishable-key"
DATABASE_URL="postgresql://user:password@host:5432/postgres"

APP_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
REFRESH_INTERVAL_MINUTES=0
ENABLE_BROKER_CONNECTORS=false
