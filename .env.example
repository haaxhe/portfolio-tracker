# === Web MVP mode ===
ENVIRONMENT=local
AUTH_MODE=local
DEFAULT_USER_ID=local-user
API_TOKEN=
TRUST_PROXY_USER_HEADER=false
APP_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
ENABLE_BROKER_CONNECTORS=false

# === Production auth / database ===
# For getwealthbrief.com production, set AUTH_MODE=supabase and fill these.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
DATABASE_URL=

# === Robinhood (unofficial API via robin_stocks; disabled unless ENABLE_BROKER_CONNECTORS=true) ===
RH_USERNAME=
RH_PASSWORD=
RH_TOTP_SECRET=          # Your 2FA TOTP secret for automated login

# === E*Trade (official API; disabled unless ENABLE_BROKER_CONNECTORS=true) ===
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_SANDBOX=true      # Set to false for production

# === App Settings ===
REFRESH_INTERVAL_MINUTES=5
DB_PATH=./portfolio.db
HOST=127.0.0.1
PORT=8000
